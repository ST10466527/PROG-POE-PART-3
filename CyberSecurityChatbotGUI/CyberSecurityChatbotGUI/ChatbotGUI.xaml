<Window x:Class="PROG_POE_PART_3.ChatbotGUI"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cybersecurity Awareness Chatbot" Height="500" Width="650">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Chat display -->
        <TextBox x:Name="ChatBox"
                 Grid.Row="0"
                 IsReadOnly="True"
                 VerticalScrollBarVisibility="Auto"
                 TextWrapping="Wrap"
                 AcceptsReturn="True" />

        <!-- Quiz/chat input -->
        <TextBox x:Name="UserInput"
                 Grid.Row="1"
                 Height="30"
                 Margin="0,5,0,5" />

        <!-- Task input -->
        <TextBox x:Name="TaskInput"
                 Grid.Row="2"
                 Height="30"
                 Margin="0,5,0,5" />

        <!-- Buttons -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5,0,0">
            <Button x:Name="SendButton" Content="Send" Width="80" Margin="5" Click="SendButton_Click"/>
            <Button x:Name="AddTask" Content="Add Task" Width="80" Margin="5" Click="AddTask_Click"/>
            <Button x:Name="ViewTasks" Content="View Tasks" Width="80" Margin="5" Click="ViewTasks_Click"/>
            <Button x:Name="StartQuiz" Content="Start Quiz" Width="80" Margin="5" Click="StartQuiz_Click"/>
            <Button x:Name="ShowLog" Content="Show Log" Width="80" Margin="5" Click="ShowLog_Click"/>
        </StackPanel>
    </Grid>
</Window>

